    gap: 8px;
}

.ger-tab.active,
.ger-tab:hover {
    background: rgba(249, 115, 22, 0.12);
    color: var(--accent);
    border-color: rgba(249, 115, 22, 0.3);
    transform: translateY(-1px);
}


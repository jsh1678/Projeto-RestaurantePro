.form-select.is-invalid {
    border-color: #ef4444;
}

.invalid-feedback {
    color: #f87171;
    font-size: 11px;
    margin-top: 5px;
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
}

#email-hint {
    font-size: 11px;

            'quantidade_atual' => 'required|numeric|min:0',
            'quantidade_minima'=> 'required|numeric|min:0',
            'preco_unitario'   => 'required|numeric|min:0',
        ]);
        StockItem::create($v);
        return back()->with('success', '✅ Produto cadastrado!');
